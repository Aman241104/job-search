# Copy to .env and fill in your own values (or run: python scripts/setup.py
# for a guided walkthrough of every step below).

# Postgres (Supabase free tier — https://supabase.com, create a project,
# copy the pooled connection string from Project Settings -> Database).
# Tables are created automatically on first run, no manual SQL needed.
DATABASE_URL=postgresql://user:password@host:6543/postgres

# NVIDIA NIM (build.nvidia.com) — free tier, ~40 requests/min, primary AI
# provider for CV/cover-letter generation, job scoring, the interview
# trainer, the Learning tutor, and the legitimacy/contact-discovery features.
# Sign up free at build.nvidia.com, open any model, click "Get API Key".
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Google Gemini — fallback if NVIDIA is rate-limited or unset. Free tier,
# get a key at aistudio.google.com/apikey.
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP for the email-apply feature. Use an App Password, not your
# real password: https://myaccount.google.com/apppasswords (needs 2FA on).
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Optional — extra scraping sources, free API keys, app works fine without them.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=

# Optional — Telegram bot for job alerts + inbound "applied"/"emailed x@co.com"
# replies. Get a token from @BotFather on Telegram (/newbot), get your chat ID
# by messaging your new bot once then hitting
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Any random string — verifies inbound webhook calls actually came from
# Telegram. Passed to setWebhook's secret_token param.
TELEGRAM_WEBHOOK_SECRET=

# Optional — persists uploaded book/PDF files (Learning feature) across
# server restarts. Free tier at cloudinary.com — Cloud Name/API Key/API
# Secret are all on your dashboard homepage after signup.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional — needed for the Learning > Playlists feature ONLY on a deployed
# host (Cloud Run, Render, etc). Cloud hosts' datacenter IPs get blocked by
# YouTube's bot check for both caption fetches and yt-dlp downloads; a real
# browser session's cookies are yt-dlp's own documented workaround. Not
# needed locally — a home/residential IP isn't flagged.
# Export via a browser extension like "Get cookies.txt LOCALLY" while logged
# into youtube.com, then paste the ENTIRE file's contents here as one value
# (it's Netscape cookie-file format, one line per cookie — keep it on one
# .env line, or wrap in quotes if your tooling requires it).
YOUTUBE_COOKIES=

# Optional, LOCAL DEV ONLY — never set these in a deployed environment.
# Uses your local `claude login` session (Pro/Max subscription usage, not API
# billing) for CV/cover-letter generation only. Falls back to NVIDIA/Gemini
# automatically if unset, or if the claude CLI isn't installed/logged in.
# AI_PROVIDER=claude_code
# CLAUDE_CODE_BIN=claude
